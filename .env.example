# ──────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in real values.
# All VITE_* vars are INLINED INTO THE CLIENT BUNDLE and visible to
# anyone who opens the site. Only put values here that are safe to be
# public. Never put a Cloudinary API secret, a database password, or
# any true secret in a VITE_ variable — those belong on a backend.
# When deploying, set these in your host (Vercel/Netlify/etc.).
# ──────────────────────────────────────────────────────────────

# Firebase web config — public by design; secure your data with Firebase Security Rules
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudinary — use an UNSIGNED upload preset for client uploads (no API secret needed)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Admin login — WARNING: this is a client-side check and offers no real security.
# Anyone can read it from the bundle. Replace with real (server-side) auth.
VITE_ADMIN_USERNAME=admin1
VITE_ADMIN_PASSWORD=change-me

# ──────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — used by `npm run seed:admin` (NOT the web app).
# These are NOT VITE_ vars, so they are never bundled into the client.
# The service-account key is a true secret — keep the JSON file out of git.
# ──────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json
SEED_ADMIN_EMAIL=admin@ecell.ipsacademy.org
SEED_ADMIN_PASSWORD=a-strong-password
SEED_ADMIN_NAME=E-Cell Admin
SEED_ADMIN_ROLE=Super Admin
